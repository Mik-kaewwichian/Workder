# =========================
# ROOT ENV EXAMPLE
# Copy to each app as needed:
# - FRONTEND/WEB/.env.local
# - FRONTEND/MOBILE/.env
# - BACKEND/API/.env
# =========================

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000

# Database (PostgreSQL)
DATABASE_URL=postgresql://workder:workder@localhost:5432/workder?schema=public

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Storage (S3/R2/etc)
STORAGE_PROVIDER=s3
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# Auth
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OTP/SMS (optional)
SMS_PROVIDER=
SMS_API_KEY=

# Email (optional)
EMAIL_PROVIDER=
EMAIL_API_KEY=

# Wallet / Payments
# provider: mock (dev, instant success) | omise (PromptPay, live)
PAYMENT_PROVIDER=mock
OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=
OMISE_WEBHOOK_SECRET=
# Platform commission in basis points (1000 = 10%), deducted from worker payout
PLATFORM_FEE_BPS=1000
# Amounts in satang (1 THB = 100 satang)
WITHDRAWAL_MIN_AMOUNT=10000
WITHDRAWAL_FEE=0
# Days before escrow auto-releases to worker if employer doesn't confirm/dispute
ESCROW_AUTO_RELEASE_DAYS=3

# Analytics (optional)
ANALYTICS_KEY=
