# =========================
# ROOT ENV EXAMPLE
# Copy to each app as needed:
# - FRONTEND/WEB/.env.local
# - FRONTEND/MOBILE/.env
# - BACKEND/API/.env
# =========================

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000

# Database (PostgreSQL)
DATABASE_URL=postgresql://workder:workder@localhost:5432/workder?schema=public

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Storage (S3/R2/etc)
STORAGE_PROVIDER=s3
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# Auth
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# OTP/SMS (optional)
SMS_PROVIDER=
SMS_API_KEY=

# Email (optional)
EMAIL_PROVIDER=
EMAIL_API_KEY=

# Payments (optional)
PAYMENT_PROVIDER=
PAYMENT_SECRET_KEY=
PAYMENT_WEBHOOK_SECRET=

# Analytics (optional)
ANALYTICS_KEY=
