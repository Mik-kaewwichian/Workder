generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id    Int     @id @default(autoincrement())
  phone String? @unique
  email String? @unique
  role  String  @default("user")
  passwordHash String?

  // Profile fields
  firstName String?
  lastName  String?
  idCard    String?

  // Address details
  address     String?
  province    String?
  district    String?
  subDistrict String?
  zipCode     String?

  // Avatar & banner
  avatar           String?
  banner           String?

  // KYC Info
  birthDate        DateTime?
  occupation       String?
  income           Int?
  education        String?
  certificates     String?
  idCardFront      String?
  idCardBack       String?
  idCardSelfie     String?
  faceScan         String?
  profileCompleted Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobsPosted            Job[]         @relation("JobsPosted")
  applicationsSubmitted Application[] @relation("WorkerApplications")
  reviewsWritten        Review[]      @relation("ReviewsWritten")
  workerPosts           WorkerPost[]  @relation("WorkerPosts")

  conversationsAsEmployer Conversation[] @relation("ConversationsAsEmployer")
  conversationsAsWorker   Conversation[] @relation("ConversationsAsWorker")
  messagesSent            Message[]      @relation("MessagesSent")

  userReviewsWritten  UserReview[] @relation("UserReviewsWritten")
  userReviewsReceived UserReview[] @relation("UserReviewsReceived")

  wallet            Wallet?
  bankAccounts      BankAccount[]
  topUps            TopUp[]
  withdrawals       Withdrawal[]
  escrowsAsEmployer Escrow[]      @relation("EscrowEmployer")
  escrowsAsWorker   Escrow[]      @relation("EscrowWorker")

  notifications     Notification[]
}

model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int       // recipient
  type      String    // 'application_received' | 'application_accepted' | 'application_rejected'
  title     String
  body      String
  link      String?   // optional in-app navigation URL
  refType   String?   // 'application' | 'job' | etc.
  refId     Int?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model UserReview {
  id        Int      @id @default(autoincrement())
  authorId  Int
  targetId  Int
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  author User @relation("UserReviewsWritten", fields: [authorId], references: [id])
  target User @relation("UserReviewsReceived", fields: [targetId], references: [id])

  @@unique([authorId, targetId])
}

model Job {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  type        String // urgent | parttime | fulltime | safezone
  status      String   @default("open")
  payAmount   Int
  lat         Float?
  lng         Float?
  safeZoneReq Boolean  @default(false)
  image1      String?
  image2      String?
  image3      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  postedById Int?
  postedBy   User? @relation("JobsPosted", fields: [postedById], references: [id])

  applications  Application[]
  reviews       Review[]
  conversations Conversation[]
  escrows       Escrow[]
}

model Application {
  id        Int      @id @default(autoincrement())
  jobId     Int
  workerId  Int
  status    String   @default("pending") // pending | accepted | rejected
  message   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  worker User @relation("WorkerApplications", fields: [workerId], references: [id])
  escrow Escrow?

  @@unique([jobId, workerId])
}

model Review {
  id        Int      @id @default(autoincrement())
  jobId     Int
  authorId  Int
  rating    Int      // 1-5
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job    Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  author User @relation("ReviewsWritten", fields: [authorId], references: [id])

  @@unique([jobId, authorId])
}

model WorkerPost {
  id          Int      @id @default(autoincrement())
  workerId    Int
  headline    String
  skills      String   // comma-separated list
  description String?
  expectedPay Int?
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  worker User @relation("WorkerPosts", fields: [workerId], references: [id], onDelete: Cascade)
}

model Conversation {
  id         Int      @id @default(autoincrement())
  jobId      Int?
  employerId Int
  workerId   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  job      Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  employer User      @relation("ConversationsAsEmployer", fields: [employerId], references: [id])
  worker   User      @relation("ConversationsAsWorker", fields: [workerId], references: [id])
  messages Message[]

  @@unique([employerId, workerId])
}

model Message {
  id             Int       @id @default(autoincrement())
  conversationId Int
  senderId       Int
  text           String
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessagesSent", fields: [senderId], references: [id])
}

// ── Wallet ──────────────────────────────────────────────────────────────────
// All money amounts are integer satang (1 THB = 100 satang) to avoid float
// rounding. Enums are String constants (SQLite has no enum support).

model Wallet {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  balance   Int      @default(0) // available balance, satang
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
}

model WalletTransaction {
  id           Int      @id @default(autoincrement())
  walletId     Int
  type         String // TOPUP | ESCROW_HOLD | ESCROW_RELEASE | ESCROW_REFUND | PAYOUT | FEE | ADJUSTMENT
  amount       Int // signed, satang (credit > 0, debit < 0)
  balanceAfter Int // wallet balance after this entry, satang
  refType      String? // topup | escrow | withdrawal | adjustment
  refId        Int?
  description  String?
  createdAt    DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
}

model Escrow {
  id            Int       @id @default(autoincrement())
  jobId         Int
  applicationId Int       @unique
  employerId    Int
  workerId      Int
  amount        Int // total held, satang
  feeAmount     Int       @default(0) // platform fee, satang (deducted from worker payout)
  status        String    @default("HELD") // HELD | PENDING_CONFIRMATION | RELEASED | REFUNDED | DISPUTED
  createdAt     DateTime  @default(now())
  releasedAt    DateTime?

  // Completion lifecycle
  workerMarkedDoneAt DateTime? // worker pressed "work done" — starts the timer
  autoReleaseAt      DateTime? // workerMarkedDoneAt + ESCROW_AUTO_RELEASE_DAYS
  disputedAt         DateTime?
  disputeReason      String?
  proofPhotos        String?   // JSON array of base64 or URL strings uploaded by worker

  job         Job         @relation(fields: [jobId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  employer    User        @relation("EscrowEmployer", fields: [employerId], references: [id])
  worker      User        @relation("EscrowWorker", fields: [workerId], references: [id])
}

model TopUp {
  id               Int       @id @default(autoincrement())
  userId           Int
  amount           Int // satang
  provider         String    @default("omise")
  providerChargeId String?   @unique
  qrPayload        String? // PromptPay QR payload / image URL
  status           String    @default("PENDING") // PENDING | PAID | EXPIRED | FAILED
  createdAt        DateTime  @default(now())
  paidAt           DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id            Int      @id @default(autoincrement())
  userId        Int
  bankCode      String
  bankName      String
  accountNumber String
  accountName   String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  withdrawals Withdrawal[]
}

model Withdrawal {
  id                 Int       @id @default(autoincrement())
  userId             Int
  bankAccountId      Int?
  amount             Int // satang
  feeAmount          Int       @default(0) // satang
  bankName           String // snapshot at request time
  accountNumber      String // snapshot at request time
  accountName        String // snapshot at request time
  status             String    @default("REQUESTED") // REQUESTED | APPROVED | PAID | REJECTED
  providerTransferId String?
  createdAt          DateTime  @default(now())
  processedAt        DateTime?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  bankAccount BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
}
